{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lumina",
  "version": "0.1.0",
  "identifier": "com.yubei.lumina",
  "mainBinaryName": "Lumina",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lumina - Developer Assistant",
        "width": 1280,
        "height": 820,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/logo.ico",
      "icons/logo.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/logo.ico"
      }
    }
  }
}
